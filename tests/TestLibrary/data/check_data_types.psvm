fn main(): int {

    let x: int = 42;
    let y: float = 3.14;
    let sum = x + y;

    printf(sum, 2);
    print("\n");
    
    print(itos(123));
    print("\n");

    print(ftos(3.14159, 2));
    print("\n");

    printi(ftoi(3.9));
    print("\n");

    printi(stoi("456"));
    print("\n");

    return 0;
}